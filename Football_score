#include <stdio.h>

void search_combo(int score) {
    int td, td1, td2, fg, safety;
    printf(" %d:\n", score);
    int found = 0;
    for (td2 = 0; td2 * 8 <= score; td2++) {
        for (td1 = 0; td1 * 7 + td2 * 8 <= score; td1++) {
            for (td = 0; td * 6 + td1 * 7 + td2 * 8 <= score; td++) { 
                for (fg = 0; fg * 3 + td * 6 + td1 * 7 + td2 * 8 <= score; fg++) {
                    for (safety = 0; safety * 2 + fg * 3 + td * 6 + td1 * 7 + td2 * 8 <= score; safety++) {
                        if (td2 * 8 + td1 * 7 + td * 6 + fg * 3 + safety * 2 == score) {
                            printf("%d TD + 2pt, %d TD + FG, %d TD, %d 3pt FG, %d Safety\n", td2, td1, td, fg, safety);
                        
                            found = 1;
                        }
                    }
                }
            }
        }
    }


    if (!found){
        printf("No possible combinations can be found");
    }
}
int main(){
    int score;
    
    while (1) {
        printf("Enter NFL score (1 to stop): ");
        if (scanf("%d", &score) != 1) {
            printf("Invalid input. Please enter an integer \n");
            while (getchar() != '\n');
            continue;
        }
        
        if (score == 1) {
            printf("Exiting program.\n");
            break; 
        }
        
        if (score < 2) {
            printf("Invalid score. Enter a number greater than or equal to 2.\n");
            continue;
        }
        
        search_combo(score);
    }
    return 0;
}



